{
    "name": "kpic-mcp-server",
    "version": "1.0.1",
    "description": "MCP Server for Korea Pharmaceutical Information Center (KPIC) API",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "dev": "tsc -p tsconfig.build.json --watch",
        "start": "node dist/index.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "lint": "eslint src --ext .ts",
        "format": "prettier --write \"src/**/*.ts\""
    },
    "keywords": [
        "mcp",
        "model-context-protocol",
        "pharmaceutical",
        "kpic",
        "drug-information"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.26.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@jest/globals": "^30.2.0",
        "@types/jest": "^29.5.12",
        "@types/node": "^20.19.26",
        "@typescript-eslint/eslint-plugin": "^7.0.1",
        "@typescript-eslint/parser": "^7.0.1",
        "eslint": "^8.56.0",
        "jest": "^29.7.0",
        "prettier": "^3.9.6",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "packageManager": "pnpm@8.15.0",
    "pnpm": {
        "overrides": {
            "hono": "^4.12.27",
            "@hono/node-server": "^2.0.5",
            "express-rate-limit": "^8.2.2",
            "path-to-regexp": "^8.4.0",
            "qs": "^6.15.2",
            "body-parser": "^2.3.0",
            "fast-uri": "^3.1.4",
            "ip-address": "^10.1.1",
            "handlebars": "^4.7.9",
            "flatted": "^3.4.2",
            "@babel/core": "^7.29.6",
            "diff@4": "^4.0.4",
            "ajv@8": "^8.18.0",
            "ajv@6": "^6.14.0",
            "js-yaml@4": "^4.3.0",
            "js-yaml@3": "^3.15.0",
            "brace-expansion@2": "^2.1.2",
            "brace-expansion@1": "^1.1.16",
            "minimatch@9": "^9.0.7",
            "minimatch@3": "^3.1.3",
            "picomatch@4": "^4.0.4",
            "picomatch@2": "^2.3.2"
        }
    }
}